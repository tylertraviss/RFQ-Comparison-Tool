generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RFQSession {
  id        String          @id @default(cuid())
  name      String
  intelJson Json?
  createdAt DateTime        @default(now())
  quotes    SupplierQuote[]
}

model SupplierQuote {
  id           String      @id @default(cuid())
  sessionId    String
  session      RFQSession  @relation(fields: [sessionId], references: [id])
  supplierName String
  rawText      String
  lineItems    LineItem[]
}

model LineItem {
  id           String        @id @default(cuid())
  quoteId      String
  quote        SupplierQuote @relation(fields: [quoteId], references: [id])
  partNumber   String
  description  String?
  quantity     Float?
  unitPrice    Float?
  leadTimeDays Int?
  notes        String?
}

model Bid {
  id           String    @id @default(cuid())
  partNumber   String
  description  String?
  supplierName String
  unitCost     Float
  unitSell     Float
  unitProfit   Float
  quantity     Int
  leadTimeDays Int?
  markup       Float
  status       BidStatus @default(WAITING)
  lostBy       Float?
  bidDate      DateTime  @default(now())
  sessionId    String?
}

enum BidStatus {
  WAITING
  WON
  LOST
}
